// Schema Prisma inicial MINIMO — Fase 1 (docs/16 §11).
// Sem PII, sem pagamento, sem documentos. Apenas o necessario para provar a stack.
// NAO ha migrations nesta fase (schema ainda nao congelado — docs/12 §20 / docs/15 §7).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Catalogo de tipos de processo. MVP: apenas Guia de Trafego. Ver docs/12 §3.4.
model ProcessType {
  id           String    @id @default(uuid())
  code         String    @unique
  name         String
  baseFeeCents Int       @map("base_fee_cents")
  active       Boolean   @default(true)
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  processes    Process[]

  @@map("process_types")
}

/// Processo SEM PII (Fases 1–3). Campos sensiveis (documento, pagamento, GRU,
/// endereco SIGMA) chegam em fases posteriores. Ver docs/12 §3.3.
/// `userId` e o id do usuario MOCK (Fase 2) — vira FK para `users` quando a
/// auth real entrar (docs/15 §3.8).
model Process {
  id               String           @id @default(uuid())
  code             String           @unique
  userId           String           @map("user_id")
  processTypeId    String           @map("process_type_id")
  processType      ProcessType      @relation(fields: [processTypeId], references: [id])
  internalStatus   InternalStatus   @default(RASCUNHO) @map("internal_status")
  userFacingStatus UserFacingStatus @default(RECEBIDO) @map("user_facing_status")
  /// Trilha OPERACIONAL do modo dev/assistido (Fase 6). Nao substitui
  /// `internalStatus` (docs/12 §6, canonico, com estados SINARM/GRU): e a visao
  /// que a fila/operacao usa enquanto nao ha protocolo real. As transicoes
  /// sincronizam `userFacingStatus` para o usuario nao ver algo divergente.
  operationalStatus OperationalStatus     @default(RASCUNHO) @map("operational_status")
  priority          ProcessPriority       @default(NORMAL)
  /// Responsavel atual (usuario MOCK — docs/11 §4). Vira FK com auth real.
  assignedToMockUserId String?             @map("assigned_to_mock_user_id")
  notes             ProcessNote[]
  /// Etapa da EXECUCAO ASSISTIDA MANUAL (Fase 7, docs/21). Descreve o que o
  /// OPERADOR HUMANO declarou ter feito FORA do app. O sistema nao acessa
  /// Gov.br/SINARM, nao automatiza e nao protocola.
  manualExecutionStatus ManualExecutionStatus @default(EXECUCAO_MANUAL_NAO_INICIADA) @map("manual_execution_status")
  manualExecution   ManualExecution?
  /// Padrao "Guia para treino", editavel (docs/10 §4).
  justification    String                 @map("justification")
  destination      Destination?
  firearm          FirearmPce?
  statusEvents     ProcessStatusEvent[]
  checklistItems   ProcessChecklistItem[]
  documents        ProcessDocument[]
  payments         Payment[]
  createdAt        DateTime               @default(now()) @map("created_at")
  updatedAt        DateTime               @updatedAt @map("updated_at")

  @@index([userId])
  @@index([operationalStatus])
  @@index([assignedToMockUserId])
  @@map("processes")
}

/// Status operacional da fila em modo dev/assistido (Fase 6).
/// NAO inclui estados de protocolo/GRU real — o MVP e assistido e nada e
/// protocolado nesta fase (docs/10 §17, docs/11 §20).
enum OperationalStatus {
  RASCUNHO
  DOCUMENTO_ENVIADO
  DOCUMENTO_APROVADO
  AGUARDANDO_PAGAMENTO
  PAGO_EM_FILA
  EM_REVISAO_OPERACIONAL
  /// Pronto para o operador protocolar MANUALMENTE no SINARM (fora do app).
  PRONTO_PARA_PROTOCOLO_MANUAL
  BLOQUEADO
  /// Cancelamento em ambiente de desenvolvimento (nao e reembolso real).
  CANCELADO_DEV

  @@map("operational_status")
}

/// Etapas da execucao assistida MANUAL (docs/21 §8).
/// Cada estado descreve uma DECLARACAO do operador humano sobre algo feito
/// fora do app. Nenhum estado faz o sistema agir no orgao.
enum ManualExecutionStatus {
  EXECUCAO_MANUAL_NAO_INICIADA
  GOVBR_ABERTO_PELO_OPERADOR
  SINARM_ABERTO_PELO_OPERADOR
  FORMULARIO_PREENCHIDO_MANUALMENTE
  CHECKPOINT_DADOS_GRU_CONFERIDO
  PROTOCOLO_MANUAL_REGISTRADO
  GRU_MANUAL_REGISTRADA
  AGUARDANDO_PAGAMENTO_GRU_EMPRESA
  GRU_PAGA_MANUALMENTE_DEV
  BLOQUEADO_OPERACIONALMENTE

  @@map("manual_execution_status")
}

/// Registro do que o HUMANO fez fora do app (docs/21 §6) — protocolo, dados da
/// GRU e pagamento da GRU pela empresa. Em modo dev/ficticio: NUNCA protocolo
/// real, NUNCA GRU real de producao. O app nao gerou nada disso.
model ManualExecution {
  id        String  @id @default(uuid())
  processId String  @unique @map("process_id")
  process   Process @relation(fields: [processId], references: [id])

  /// --- Protocolo registrado manualmente (ficticio/dev) ---
  protocolNumber                 String?   @map("protocol_number")
  protocolObservation            String?   @map("protocol_observation")
  protocolRegisteredByMockUserId String?   @map("protocol_registered_by_mock_user_id")
  protocolRegisteredByRole       String?   @map("protocol_registered_by_role")
  protocolRegisteredAt           DateTime? @map("protocol_registered_at")

  /// --- Dados da GRU registrados manualmente (ficticios/dev) ---
  gruReference              String?   @map("gru_reference")
  /// Vencimento LIDO do sistema pelo operador — nunca fixado pelo app (docs/10 §4).
  gruDueDate                DateTime? @map("gru_due_date")
  gruAmountCents            Int?      @map("gru_amount_cents")
  gruObservation            String?   @map("gru_observation")
  gruRegisteredByMockUserId String?   @map("gru_registered_by_mock_user_id")
  gruRegisteredByRole       String?   @map("gru_registered_by_role")
  gruRegisteredAt           DateTime? @map("gru_registered_at")

  /// --- Pagamento da GRU pela empresa (docs/11 §9), registrado pelo Financeiro ---
  gruPaidAt                        DateTime? @map("gru_paid_at")
  gruPaymentObservation            String?   @map("gru_payment_observation")
  gruPaymentRegisteredByMockUserId String?   @map("gru_payment_registered_by_mock_user_id")
  gruPaymentRegisteredByRole       String?   @map("gru_payment_registered_by_role")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("manual_executions")
}

/// Prioridade operacional da fila (docs/11 §4).
enum ProcessPriority {
  BAIXA
  NORMAL
  ALTA
  URGENTE

  @@map("process_priority")
}

/// Notas internas e mensagens ao usuario (docs/11 §5.11/§17).
/// Texto livre — a UI avisa para NAO escrever PII (docs/11 §19).
model ProcessNote {
  id               String         @id @default(uuid())
  processId        String         @map("process_id")
  process          Process        @relation(fields: [processId], references: [id])
  visibility       NoteVisibility @default(INTERNA)
  body             String
  authorMockUserId String         @map("author_mock_user_id")
  authorRole       String         @map("author_role")
  createdAt        DateTime       @default(now()) @map("created_at")

  @@index([processId])
  @@map("process_notes")
}

/// Visibilidade da nota: interna (equipe) ou mensagem ao usuario (docs/11 §11).
enum NoteVisibility {
  INTERNA
  VISIVEL_USUARIO

  @@map("note_visibility")
}

/// Historico imutavel de mudancas de status (docs/12 §3.5). APPEND-ONLY:
/// nunca editar/apagar. `actorMockUserId`/`actorRole` referem-se aos usuarios
/// MOCK da Fase 2 — viram FK/enum reais quando a auth real entrar.
model ProcessStatusEvent {
  id              String           @id @default(uuid())
  processId       String           @map("process_id")
  process         Process          @relation(fields: [processId], references: [id])
  /// Tipo do evento — a trilha cobre status, prioridade, responsavel e notas.
  kind            ProcessEventKind @default(STATUS_INTERNO)
  fromStatus      InternalStatus?  @map("from_status")
  /// Nulo em eventos que nao mudam o status interno (prioridade, responsavel…).
  toStatus        InternalStatus?  @map("to_status")
  /// Valores genericos dos eventos operacionais (rotulos curtos, SEM PII).
  fromValue       String?          @map("from_value")
  toValue         String?          @map("to_value")
  actorMockUserId String           @map("actor_mock_user_id")
  actorRole       String           @map("actor_role")
  /// Texto curto, SEM PII (docs/12 §3.5).
  note            String?
  createdAt       DateTime         @default(now()) @map("created_at")

  @@index([processId])
  @@map("process_status_events")
}

/// Tipos de evento da trilha do processo (docs/11 §18).
enum ProcessEventKind {
  STATUS_INTERNO
  STATUS_OPERACIONAL
  PRIORIDADE
  RESPONSAVEL
  NOTA
  /// Fase 7 — registros da execucao assistida MANUAL (docs/21 §9).
  EXECUCAO_MANUAL
  PROTOCOLO_MANUAL
  GRU_MANUAL
  PAGAMENTO_GRU_MANUAL

  @@map("process_event_kind")
}

/// Itens do checklist de revisao admin (docs/11 §6, versao dev/mock).
/// Registra quem marcou (usuario mock + perfil) e quando — base da futura
/// auditoria (docs/11 §18). Um item por (processo, key).
model ProcessChecklistItem {
  id                  String    @id @default(uuid())
  processId           String    @map("process_id")
  process             Process   @relation(fields: [processId], references: [id])
  /// Grupo do item: revisao geral (docs/11 §6) ou checkpoint GRU (docs/11 §7).
  group               ChecklistGroup @default(REVISAO)
  key                 String
  label               String
  checked             Boolean   @default(false)
  checkedByMockUserId String?   @map("checked_by_mock_user_id")
  checkedByRole       String?   @map("checked_by_role")
  checkedAt           DateTime? @map("checked_at")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  @@unique([processId, key])
  @@map("process_checklist_items")
}

/// Grupos de checklist: revisao geral (docs/11 §6) e checkpoint "Dados da GRU"
/// (docs/11 §7). O checkpoint GRU aqui e FICTICIO: nao acessa SINARM, nao gera
/// GRU e nao protocola — so registra a conferencia humana.
enum ChecklistGroup {
  REVISAO
  GRU
  /// Fase 7 — conferencia POS-PROTOCOLO do que o humano registrou (docs/21 §12).
  POS_PROTOCOLO

  @@map("checklist_group")
}

/// Destino/clube/evento informado pelo usuario (docs/12 §3.7). Dados de local
/// de evento — ficticios nesta fase; nao ha PII de pessoa.
model Destination {
  id        String   @id @default(uuid())
  processId String   @unique @map("process_id")
  process   Process  @relation(fields: [processId], references: [id])
  eventName String   @map("event_name")
  uf        String
  city      String
  street    String
  number    String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("destinations")
}

/// Arma/PCE indicada — SUBCONJUNTO NAO SENSIVEL do docs/12 §3.8.
/// Campos cifrados (sigma_number, serial_number, lot_number) ficam FORA ate a
/// decisao de criptografia 3.10 (docs/15). Nesta fase, os valores vem de um
/// catalogo MOCK 100% ficticio (src/server/processes/mockFirearms.ts).
model FirearmPce {
  id        String   @id @default(uuid())
  processId String   @unique @map("process_id")
  process   Process  @relation(fields: [processId], references: [id])
  /// Id do item no catalogo mock — para rastrear a escolha em dev.
  mockCatalogId String @map("mock_catalog_id")
  species   String
  brand     String
  model     String
  caliber   String
  quantity  Int      @default(1)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("firearms_pce")
}

/// Documento anexado ao processo (docs/12 §3.6) — Fase 4 em modo DEV/FICTICIO.
/// Os BYTES ficam no storage local/dev (adapter), NUNCA no banco. Apenas
/// metadados + sha256 aqui. SEM documento real, SEM PII real (docs/15 §3.2/§3.10).
model ProcessDocument {
  id                   String         @id @default(uuid())
  processId            String         @map("process_id")
  process              Process        @relation(fields: [processId], references: [id])
  type                 DocumentType   @default(IDENTIFICACAO_PESSOAL)
  status               DocumentStatus @default(ENVIADO)
  originalFileName     String         @map("original_file_name")
  mimeType             String         @map("mime_type")
  sizeBytes            Int            @map("size_bytes")
  sha256               String
  storageKey           String         @map("storage_key")
  uploadedByMockUserId String         @map("uploaded_by_mock_user_id")
  reviewedByMockUserId String?        @map("reviewed_by_mock_user_id")
  reviewedByRole       String?        @map("reviewed_by_role")
  reviewedAt           DateTime?      @map("reviewed_at")
  /// Motivo curto, SEM reproduzir PII do documento (docs/11 §14).
  rejectionReason      String?        @map("rejection_reason")
  createdAt            DateTime       @default(now()) @map("created_at")
  updatedAt            DateTime       @updatedAt @map("updated_at")

  @@index([processId])
  @@map("process_documents")
}

/// Pagamento Pix do cliente (docs/12 §3.9) — Fase 5 em modo SANDBOX/DEV.
/// NUNCA cobranca real nesta fase (docs/15 §3.4): provider "fake" (dev) ou
/// Mercado Pago SANDBOX. `webhookEventId` unico garante idempotencia do webhook.
model Payment {
  id                String        @id @default(uuid())
  processId         String        @map("process_id")
  process           Process       @relation(fields: [processId], references: [id])
  provider          String // "fake" | "mercadopago" (adapter — docs/15 §3.4)
  providerPaymentId String?       @map("provider_payment_id")
  status            PaymentStatus @default(PENDENTE)
  amountCents       Int           @map("amount_cents")
  currency          String        @default("BRL")
  /// Payload do QR (sandbox/dev: texto claramente ficticio, nunca EMV real).
  pixQrCode         String?       @map("pix_qr_code")
  pixCopyPaste      String?       @map("pix_copy_paste")
  expiresAt         DateTime?     @map("expires_at")
  paidAt            DateTime?     @map("paid_at")
  /// Id do evento de webhook que confirmou o pagamento (idempotencia §7 #10).
  webhookEventId    String?       @unique @map("webhook_event_id")
  createdAt         DateTime      @default(now()) @map("created_at")
  updatedAt         DateTime      @updatedAt @map("updated_at")

  @@index([processId])
  @@index([providerPaymentId])
  @@map("payments")
}

/// Estados do pagamento Pix (docs/12 §8, nomes conforme decisao da F5).
enum PaymentStatus {
  PENDENTE
  AGUARDANDO_PAGAMENTO
  PAGO
  EXPIRADO
  CANCELADO
  FALHOU

  @@map("payment_status")
}

/// Tipos de documento (docs/12 §3.6).
/// Espelha os tipos de DOMINIO (src/server/documents/documentTypes.ts) para que
/// cada documento esperado da Guia de Trafego persista com o proprio tipo.
/// Adicao PURAMENTE ADITIVA: nenhum documento existente muda de valor.
/// `COMPLEMENTAR` (dominio) persiste como OUTRO — nao ha valor duplicado aqui.
enum DocumentType {
  IDENTIFICACAO_PESSOAL
  CR_REGISTRO_CAC
  COMPROVANTE_ORIGEM_ENDERECO
  DECLARACAO_DESTINO_EVENTO
  OUTRO

  @@map("document_type")
}

/// Estados do documento (docs/12 §10, nomes conforme decisao da F4).
enum DocumentStatus {
  PENDENTE
  ENVIADO
  EM_ANALISE
  APROVADO
  REJEITADO

  @@map("document_status")
}

/// Status internos (operacao). Ver docs/12 §6.
enum InternalStatus {
  RASCUNHO
  AGUARDANDO_PAGAMENTO
  PAGO_EM_FILA
  AGUARDANDO_LOGIN_GOVBR
  SESSAO_GOVBR_EXPIRADA
  EM_PREENCHIMENTO_SINARM
  EM_REVISAO_HUMANA
  BLOQUEADO_INSTABILIDADE
  EXCECAO_DOC_INVALIDO
  EXCECAO_ARMA_DIVERGENTE
  EXCECAO_DESTINO_INCOMPLETO
  PROTOCOLADO_GRU_GERADA
  GRU_PAGA_EMPRESA
  CONCLUIDO
  CANCELADO_REEMBOLSADO

  @@map("internal_status")
}

/// Status visiveis ao usuario. Ver docs/12 §7.
enum UserFacingStatus {
  RECEBIDO
  PAGAMENTO_CONFIRMADO
  AGUARDANDO_SEU_LOGIN_GOVBR
  EM_ANDAMENTO
  AGUARDANDO_SISTEMA_PF
  PRECISAMOS_DE_UM_AJUSTE
  PROTOCOLADO
  CONCLUIDO
  CANCELADO

  @@map("user_facing_status")
}
