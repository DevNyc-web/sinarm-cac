// Schema Prisma inicial MINIMO — Fase 1 (docs/16 §11).
// Sem PII, sem pagamento, sem documentos. Apenas o necessario para provar a stack.
// NAO ha migrations nesta fase (schema ainda nao congelado — docs/12 §20 / docs/15 §7).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Catalogo de tipos de processo. MVP: apenas Guia de Trafego. Ver docs/12 §3.4.
model ProcessType {
  id           String    @id @default(uuid())
  code         String    @unique
  name         String
  baseFeeCents Int       @map("base_fee_cents")
  active       Boolean   @default(true)
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  processes    Process[]

  @@map("process_types")
}

/// Processo SEM PII (Fases 1–3). Campos sensiveis (documento, pagamento, GRU,
/// endereco SIGMA) chegam em fases posteriores. Ver docs/12 §3.3.
/// `userId` e o id do usuario MOCK (Fase 2) — vira FK para `users` quando a
/// auth real entrar (docs/15 §3.8).
model Process {
  id               String           @id @default(uuid())
  code             String           @unique
  userId           String           @map("user_id")
  processTypeId    String           @map("process_type_id")
  processType      ProcessType      @relation(fields: [processTypeId], references: [id])
  internalStatus   InternalStatus   @default(RASCUNHO) @map("internal_status")
  userFacingStatus UserFacingStatus @default(RECEBIDO) @map("user_facing_status")
  /// Padrao "Guia para treino", editavel (docs/10 §4).
  justification    String                 @map("justification")
  destination      Destination?
  firearm          FirearmPce?
  statusEvents     ProcessStatusEvent[]
  checklistItems   ProcessChecklistItem[]
  documents        ProcessDocument[]
  createdAt        DateTime               @default(now()) @map("created_at")
  updatedAt        DateTime               @updatedAt @map("updated_at")

  @@index([userId])
  @@map("processes")
}

/// Historico imutavel de mudancas de status (docs/12 §3.5). APPEND-ONLY:
/// nunca editar/apagar. `actorMockUserId`/`actorRole` referem-se aos usuarios
/// MOCK da Fase 2 — viram FK/enum reais quando a auth real entrar.
model ProcessStatusEvent {
  id              String          @id @default(uuid())
  processId       String          @map("process_id")
  process         Process         @relation(fields: [processId], references: [id])
  fromStatus      InternalStatus? @map("from_status")
  toStatus        InternalStatus  @map("to_status")
  actorMockUserId String          @map("actor_mock_user_id")
  actorRole       String          @map("actor_role")
  /// Texto curto, SEM PII (docs/12 §3.5).
  note            String?
  createdAt       DateTime        @default(now()) @map("created_at")

  @@index([processId])
  @@map("process_status_events")
}

/// Itens do checklist de revisao admin (docs/11 §6, versao dev/mock).
/// Registra quem marcou (usuario mock + perfil) e quando — base da futura
/// auditoria (docs/11 §18). Um item por (processo, key).
model ProcessChecklistItem {
  id                  String    @id @default(uuid())
  processId           String    @map("process_id")
  process             Process   @relation(fields: [processId], references: [id])
  key                 String
  label               String
  checked             Boolean   @default(false)
  checkedByMockUserId String?   @map("checked_by_mock_user_id")
  checkedByRole       String?   @map("checked_by_role")
  checkedAt           DateTime? @map("checked_at")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  @@unique([processId, key])
  @@map("process_checklist_items")
}

/// Destino/clube/evento informado pelo usuario (docs/12 §3.7). Dados de local
/// de evento — ficticios nesta fase; nao ha PII de pessoa.
model Destination {
  id        String   @id @default(uuid())
  processId String   @unique @map("process_id")
  process   Process  @relation(fields: [processId], references: [id])
  eventName String   @map("event_name")
  uf        String
  city      String
  street    String
  number    String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("destinations")
}

/// Arma/PCE indicada — SUBCONJUNTO NAO SENSIVEL do docs/12 §3.8.
/// Campos cifrados (sigma_number, serial_number, lot_number) ficam FORA ate a
/// decisao de criptografia 3.10 (docs/15). Nesta fase, os valores vem de um
/// catalogo MOCK 100% ficticio (src/server/processes/mockFirearms.ts).
model FirearmPce {
  id        String   @id @default(uuid())
  processId String   @unique @map("process_id")
  process   Process  @relation(fields: [processId], references: [id])
  /// Id do item no catalogo mock — para rastrear a escolha em dev.
  mockCatalogId String @map("mock_catalog_id")
  species   String
  brand     String
  model     String
  caliber   String
  quantity  Int      @default(1)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("firearms_pce")
}

/// Documento anexado ao processo (docs/12 §3.6) — Fase 4 em modo DEV/FICTICIO.
/// Os BYTES ficam no storage local/dev (adapter), NUNCA no banco. Apenas
/// metadados + sha256 aqui. SEM documento real, SEM PII real (docs/15 §3.2/§3.10).
model ProcessDocument {
  id                   String         @id @default(uuid())
  processId            String         @map("process_id")
  process              Process        @relation(fields: [processId], references: [id])
  type                 DocumentType   @default(IDENTIFICACAO_PESSOAL)
  status               DocumentStatus @default(ENVIADO)
  originalFileName     String         @map("original_file_name")
  mimeType             String         @map("mime_type")
  sizeBytes            Int            @map("size_bytes")
  sha256               String
  storageKey           String         @map("storage_key")
  uploadedByMockUserId String         @map("uploaded_by_mock_user_id")
  reviewedByMockUserId String?        @map("reviewed_by_mock_user_id")
  reviewedByRole       String?        @map("reviewed_by_role")
  reviewedAt           DateTime?      @map("reviewed_at")
  /// Motivo curto, SEM reproduzir PII do documento (docs/11 §14).
  rejectionReason      String?        @map("rejection_reason")
  createdAt            DateTime       @default(now()) @map("created_at")
  updatedAt            DateTime       @updatedAt @map("updated_at")

  @@index([processId])
  @@map("process_documents")
}

/// Tipos de documento (docs/12 §3.6). MVP: so Documento de Identificacao.
enum DocumentType {
  IDENTIFICACAO_PESSOAL
  OUTRO

  @@map("document_type")
}

/// Estados do documento (docs/12 §10, nomes conforme decisao da F4).
enum DocumentStatus {
  PENDENTE
  ENVIADO
  EM_ANALISE
  APROVADO
  REJEITADO

  @@map("document_status")
}

/// Status internos (operacao). Ver docs/12 §6.
enum InternalStatus {
  RASCUNHO
  AGUARDANDO_PAGAMENTO
  PAGO_EM_FILA
  AGUARDANDO_LOGIN_GOVBR
  SESSAO_GOVBR_EXPIRADA
  EM_PREENCHIMENTO_SINARM
  EM_REVISAO_HUMANA
  BLOQUEADO_INSTABILIDADE
  EXCECAO_DOC_INVALIDO
  EXCECAO_ARMA_DIVERGENTE
  EXCECAO_DESTINO_INCOMPLETO
  PROTOCOLADO_GRU_GERADA
  GRU_PAGA_EMPRESA
  CONCLUIDO
  CANCELADO_REEMBOLSADO

  @@map("internal_status")
}

/// Status visiveis ao usuario. Ver docs/12 §7.
enum UserFacingStatus {
  RECEBIDO
  PAGAMENTO_CONFIRMADO
  AGUARDANDO_SEU_LOGIN_GOVBR
  EM_ANDAMENTO
  AGUARDANDO_SISTEMA_PF
  PRECISAMOS_DE_UM_AJUSTE
  PROTOCOLADO
  CONCLUIDO
  CANCELADO

  @@map("user_facing_status")
}
