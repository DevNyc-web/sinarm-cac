# === Fase 1 — esqueleto (sem segredos reais) ===
# Copie para .env e preencha localmente. NUNCA commite o .env.

# App
NODE_ENV=development
APP_URL=http://localhost:3000

# Banco (Postgres LOCAL — decisao 3.1 / docs/15)
# Use um Postgres local de desenvolvimento. NAO usar dados reais / PII real.
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/sinarm_cac_dev

# Logs (pino)
LOG_LEVEL=debug

# === Fase 5 — Pix SANDBOX/DEV (decisao 3.4 / docs/15, docs/17) ===
# NUNCA cobranca Pix real nesta fase. NUNCA credencial de producao aqui.
# "fake"        -> provider de desenvolvimento, sem credencial nenhuma.
# "mercadopago" -> SANDBOX do Mercado Pago; use APENAS o access token de TESTE
#                  (comeca com TEST-), obtido no painel de desenvolvedor.
PAYMENT_PROVIDER=fake
MERCADO_PAGO_ACCESS_TOKEN=
MERCADO_PAGO_WEBHOOK_SECRET=

