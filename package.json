{
  "name": "sinarm-cac",
  "version": "0.1.0",
  "private": true,
  "description": "Plataforma web/PWA de assistência a processos SINARM/CAC (Guia de Tráfego). Esqueleto — Fase 1.",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "seed": "tsx prisma/seed.ts",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:report": "playwright show-report",
    "test:e2e:phase9": "playwright test -c playwright.phase9.config.ts",
    "test:e2e:phase9:headed": "playwright test -c playwright.phase9.config.ts --headed",
    "test:phase9:unit": "tsx --test tests/unit/phase9/safety.test.ts tests/unit/phase9/networkGuard.test.ts tests/unit/phase9/auditLogger.test.ts tests/unit/phase9/phase9Runner.test.ts",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@prisma/client": "^6.2.0",
    "next": "^15.1.0",
    "pino": "^9.6.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/node": "^22.10.5",
    "@types/react": "^19.0.7",
    "@types/react-dom": "^19.0.3",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.1",
    "eslint-config-next": "^15.1.0",
    "postcss": "^8.4.49",
    "prettier": "^3.4.2",
    "prisma": "^6.2.0",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
